<!DOCTYPE html>
    <html>
        <head>
            <meta charset="UTF-8">
            <link rel="stylesheet" href="../css/styles.css">
            <title>Sirius Intranet System: Internal Blogs and Memos</title>
        </head>

        <body>
            <header>
                <p id="navTitle">Main Site Navigation</p>
                <nav aria-label="Sirius Intranet Main Site Navigation">
                    <ul>
                        <li><a href="/sirius-main">Main</a></li>
                        <li><a href="../html/sirius-directory.html">Directory</a></li>
                    </ul>
                </nav>
            </header>
            <main>
                <h1>House Hold Note Space</h1>
                <section>
                    <section>
                        <h2 class="highlight">Most recent Ivy News:</h2>
                            <% if (childNameMemo && childNameMemo.length > 0) { %>
                                <ul>
                                    <% childNameMemo.forEach(memo => { %>
                                        <li class="highlight"><%= memo.title %> — <%= memo.content %> (<%= memo.date %>)</li>
                                    <% }); %>
                                </ul>
                            <% } else { %>
                                <p>No matching memos found…</p>
                            <% } %>
                    </section>

                </section>
                <section>
                    <h2>House Hold Memos:</h2>
                    <h2>Recent Memos</h2>
                    <% if (recentMemos && recentMemos.length > 0) { %>
                        <ul>
                            <% recentMemos.forEach(memo => { %>
                            <li><%= memo.title %> — <%= memo.content %> (<%= memo.date %>)</li>
                            <% }); %>
                        </ul>
                    <% } else { %>
                        <p>No memos yet…</p>
                    <% } %>

                    <form id="blogFormMemo">
                        <textarea id="blogTextMemo" rows="4" cols="40" placeholder="Write your memo here..."></textarea>
                        <br>
                        <button type="submit" class="submitButton">Post</button>
                    </form>
                </section>
                
                <section>
                    <h2>House Hold Notes:</h2>
                    
                    <h2>Most Recent Note</h2>
                        <% if (recentNote && recentNote.length > 0) { %>
                            <p><%= recentNote[0].title %> — <%= recentNote[0].content %> (<%= recentNote[0].date %>)</p>
                        <% } else { %>
                            <p>No notes yet…</p>
                        <% } %>



                    <form id="blogFormNote">
                        <textarea id="blogTextNote" rows="4" cols="40" placeholder="Write your memo here..."></textarea>
                        <br>
                        <button type="submit" class="submitButton">Post</button>
                    </form>

                </section>

            </main>
            <footer>
                <p>Site Built by: Sirius  </p>
            </footer>
            <script src="../js/blog.js" defer></script>
        </body>
    </html>