                <br>
                <h2>Random Ivy Photo!</h2>
                <!--build an asset folder with Ivy photos that cycle-->
                <img src="../assets/ivy-photo-1.jpg" alt="A Photo of Ivy, but not my kid">
            </main>
            <footer>
                <p>Site Built by: Sirius  </p>
            </footer>
            <script src="../js/blog.js" defer></script>
            <script src="/popup-alert.js"></script>
        </body>
        
    </html>